
# All files
[*]
indent_style = space

# Xml files
[*.xml]
indent_size = 2

[*.cs]
dotnet_diagnostic.CA2007.severity = none

# Test method names use the xUnit `Method_Scenario_Expectation` convention (underscores carry the
# scenario), which CA1707 flags. Suppress it for the test project only — the underscores are
# intentional readability, not an API-naming concern.
dotnet_diagnostic.CA1707.severity = none